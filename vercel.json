{
  "version": 2,
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://web-production-ff9e2.up.railway.app/api/$1" },
    { "source": "/health", "destination": "https://web-production-ff9e2.up.railway.app/health" },
    { "source": "/format", "destination": "https://web-production-ff9e2.up.railway.app/format" },
    { "source": "/generate-guide", "destination": "https://web-production-ff9e2.up.railway.app/generate-guide" },
    { "source": "/guide/:path*", "destination": "https://web-production-ff9e2.up.railway.app/guide/:path*" },
    { "source": "/guides", "destination": "https://web-production-ff9e2.up.railway.app/guides" },
    { "source": "/events/:path*", "destination": "https://web-production-ff9e2.up.railway.app/events/:path*" },
    { "source": "/webhook", "destination": "https://web-production-ff9e2.up.railway.app/webhook" },
    { "source": "/demos", "destination": "https://web-production-ff9e2.up.railway.app/demos" },
    { "source": "/demo-stream/:path*", "destination": "https://web-production-ff9e2.up.railway.app/demo-stream/:path*" },
    { "source": "/mock-generate", "destination": "https://web-production-ff9e2.up.railway.app/mock-generate" },
    { "source": "/retry-guide/:path*", "destination": "https://web-production-ff9e2.up.railway.app/retry-guide/:path*" }
  ]
}
