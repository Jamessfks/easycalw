# Copy to repository root as `.env` (never commit real secrets).

# --- Vertex / Gemini (required for live + architect) ---
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=waybackhome-jncvad3wwvia6gwjnd
GOOGLE_CLOUD_LOCATION=us-central1

# Architect A2A public URL (must match how the browser / dispatch reach the service)
PUBLIC_ARCHITECT_URL=http://127.0.0.1:8081
ARCHITECT_URL=http://127.0.0.1:8081

# Models (adjust to available Vertex model IDs in your project)
ARCHITECT_MODEL=gemini-2.5-flash
DISPATCH_LIVE_MODEL=gemini-live-2.5-flash-preview-native-audio-09-2025

# Optional: Redis mirror of rulebook (docker-compose)
REDIS_HOST=
REDIS_PORT=6379

# Hub
PORT=8080
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
