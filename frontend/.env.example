# Vapi Voice AI — get these from https://dashboard.vapi.ai
VITE_VAPI_PUBLIC_KEY=your_vapi_public_key_here
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# Backend API base URL (leave empty for same-origin in production)
VITE_API_BASE=

# Set to your Railway URL for share links: https://easyclaw.up.railway.app
VITE_PUBLIC_URL=
