# VAPI Configuration
# Public key and Assistant ID have defaults in vapi_config.py
# Override here if needed:
# VAPI_ASSISTANT_ID=6aff492d-aa3b-4aaa-a9f3-8d51440dd825
# VAPI_PUBLIC_KEY=5bd9e5c5-dd9e-4021-b13d-9d6fa8395dc0

# Private key — needed for server-side VAPI API access (transcript retrieval)
# Ask the Interview Agent team for this key
VAPI_PRIVATE_KEY=

# RocketRide Configuration
# Engine runs via Docker: docker run -d -p 5565:5565 ghcr.io/rocketride-org/rocketride-engine:latest
ROCKETRIDE_URI=ws://localhost:5565
ROCKETRIDE_APIKEY=

# LLM API key for RocketRide pipelines (formatter + guide creation)
ROCKETRIDE_APIKEY_ANTHROPIC=
