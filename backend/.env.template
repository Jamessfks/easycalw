# ============================================
# EasyClaw Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# cp .env.template .env

# Anthropic API key — used by both the formatter (Haiku fallback) and the Setup Guide Agent (Sonnet)
ANTHROPIC_API_KEY=

# Gemini API key — used by the formatter primary path (Gemini Flash)
GEMINI_API_KEY=

# VAPI Assistant ID — identifies the pre-built Interview Agent in VAPI
VAPI_ASSISTANT_ID=

# VAPI Public Key — used by the frontend SDK to start calls
VAPI_PUBLIC_KEY=

# VAPI Private Key — needed for server-side VAPI API access (optional)
VAPI_PRIVATE_KEY=

# VAPI Webhook Secret — used for HMAC signature verification on /webhook
# Leave empty to skip verification (dev mode — logs a warning)
VAPI_WEBHOOK_SECRET=

# CORS origins — comma-separated list, or "*" for development
# Example: http://localhost:5173,https://easyclaw.yourdomain.com
CORS_ORIGINS=*

# Guide output directory (default: ./guide_output)
GUIDE_OUTPUT_DIR=./guide_output

# Guide store persistence path (default: /tmp/easyclaw_guide_store.json)
# GUIDE_STORE_PATH=/tmp/easyclaw_guide_store.json

# Server port (default: 8000)
# PORT=8000
