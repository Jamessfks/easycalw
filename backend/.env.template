# Anthropic API key — used by both the formatter (Haiku) and the Setup Guide Agent (Sonnet)
ANTHROPIC_API_KEY=

# VAPI Private key — needed for server-side VAPI API access
VAPI_PRIVATE_KEY=

# CORS origins — comma-separated list, or "*" for development
# Example: http://localhost:5173,https://easyclaw.yourdomain.com
CORS_ORIGINS=*

# Guide output directory (default: /tmp/openclaw-guides)
# GUIDE_OUTPUT_DIR=/tmp/openclaw-guides

# Guide store persistence path (default: /tmp/easyclaw_guide_store.json)
# GUIDE_STORE_PATH=/tmp/easyclaw_guide_store.json

# Server port (default: 8000)
# PORT=8000
